{
  "name": "nayra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:dev:create": "NODE_ENV=development tsx scripts/db-create.ts",
    "db:dev:migrate": "NODE_ENV=development drizzle-kit migrate",
    "db:dev:seed": "NODE_ENV=development tsx scripts/db-seed.ts",
    "db:dev:setup": "pnpm db:dev:create && pnpm db:dev:migrate && pnpm db:dev:seed",
    "db:test:create": "NODE_ENV=test tsx scripts/db-create.ts",
    "db:test:migrate": "NODE_ENV=test drizzle-kit migrate",
    "db:test:seed": "NODE_ENV=test tsx scripts/db-seed.ts",
    "db:test:setup": "pnpm db:test:create && pnpm db:test:migrate && pnpm db:test:seed",
    "db:dump": "NODE_ENV=development tsx scripts/db-dump.ts",
    "db:load": "tsx scripts/db-load.ts",
    "db:load:bundle": "esbuild scripts/db-load.ts --bundle --platform=node --format=cjs --tsconfig=tsconfig.json --outfile=dist/db-load.cjs",
    "storage:reset": "tsx scripts/storage-reset.ts",
    "db:reset": "tsx scripts/db-load.ts && tsx scripts/storage-reset.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@blocknote/core": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@blocknote/shadcn": "^0.51.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lodash": "^4.18.1",
    "lucide-react": "^0.577.0",
    "neverthrow": "^8.2.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuidv7": "^1.1.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
