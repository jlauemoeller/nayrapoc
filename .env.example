# Copy this file and fill in values for your environment.
#
#   Local development:  cp .env.example .env.development.local
#   Local test runs:    cp .env.example .env.test.local
#
# Do NOT commit .env.development.local or .env.test.local.

DATABASE_URL=postgres://user:password@localhost:5432/nayra_dev

NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

EMAIL_SERVER_USER=username
EMAIL_SERVER_PASSWORD=password
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_FROM=noreply@nayra.com

OBJECT_STORAGE_ACCESS_KEY_ID="your access key id"
OBJECT_STORAGE_SECRET_ACCESS_KEY="your secret access key"
OBJECT_STORAGE_ENDPOINT="http://localhost:9000"
OBJECT_STORAGE_BUCKET="your bucket name"
OBJECT_STORAGE_REGION="us-east-1"
# Set to "true" for Minio and other path-style S3-compatible providers.
OBJECT_STORAGE_FORCE_PATH_STYLE="true"
# Public base URL used to render uploaded images (server-side only).
# Defaults to OBJECT_STORAGE_ENDPOINT if unset.
OBJECT_STORAGE_PUBLIC_URL="http://localhost:9000"

